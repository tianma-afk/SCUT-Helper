# 同级目录创建.env 文件，将该文件内容拷贝到.env文件中，然后修改里面的内容
DB_HOST=db
DB_PORT=3306
DB_NAME=scut_helper
DB_USER=app_user
DB_PASSWORD=your_real_password_here
DB_CHARSET=utf8mb4

#QQ邮箱配置
SMTP_HOST = smtp.qq.com       # SMTP服务器地址
SMTP_PORT = 465                 # SMTP端口（SSL加密）
SMTP_USER = 你的邮箱账号@qq.com # 发件人邮箱
SMTP_PASS = 你的邮箱SMTP授权码  # 邮箱SMTP授权码（非登录密码）
SENDER_NAME = 鲤工助手    # 发件人显示名称

# JWT_SECRET_KEY 为JWT密钥，请自行修改
JWT_SECRET_KEY=your_jwt_secret_key_here

#HTTPS配置，注意！两个pem文件放在/scut_helper/backend/ssl文件夹下
SSL_KEYFILE = ./ssl/key.pem
SSL_CERTFILE = ./ssl/cert.pem
PORT = 8443